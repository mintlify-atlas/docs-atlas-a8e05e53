  "keyFeatures": [
    "Mechanism base class wrapping CTRE TalonFX/Kraken motor controllers for simplified configuration and control",
    "Trigger-based state machine eliminating complex command group nesting",
    "Full robot simulation with IronMaple season-specific physics (Roller, Linear, Arm mechanisms)",
    "SpectrumLib reusable utility library (CachedDouble, LED management, gamepad abstraction)",
    "Multi-robot configuration support (FM2026, XM2026, PM2026, AM2026) via Rio ID",
    "Vision-assisted pose estimation with Limelight MegaTag and PhotonVision AprilTag fusion",
    "PathPlanner-based autonomous routines with event markers",
    "CANdle LED subsystem with animation priorities and multi-strip support"
  ],
  "publicApiSurface": [
    "Mechanism (abstract base class for TalonFX-driven subsystems)",
    "SpectrumSubsystem (base WPILib subsystem wrapper)",
    "SpectrumRobot (base robot class)",
    "CachedDouble (CANbus-efficient cached sensor value)",
    "TalonFXFactory (motor configuration factory)",
    "SpectrumCANcoder / SpectrumCANcoderConfig",
    "SpectrumServo",
    "SpectrumState (holdable boolean trigger)",
    "RobotStates.setupStates() (trigger-to-command binding entry point)",
    "Coordinator (multi-subsystem state coordinator)",
    "Robot.Config / XM2026 / PM2026 / FM2026 / AM2026 (hardware configuration classes)"
  ]
}
